{
  "version": 2,
  "functions": {
    "api/index.py": {
      "includeFiles": "static/**"
    }
  },
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
